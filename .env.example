# Runtime environment: dev, test, or prod.
APP_ENV=dev

# Local Docker Compose defaults. Use injected secrets/URLs outside local development.
DATABASE_URL=postgresql://postgres:postgres@db:5432/stock_db
REDIS_URL=redis://redis:6379/0

# Security settings. Replace SECRET_KEY in every real environment; never commit real secrets.
SECRET_KEY=change-me-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=2880

# Optional LLM provider settings. Leave OPENAI_API_KEY empty for mock-only local flows.
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=30

# Data provider switches: mock uses deterministic local adapters, real selects external adapters.
# Real providers are only valid where the corresponding adapter and credentials are configured.
MARKET_PROVIDER=mock
NEWS_PROVIDER=mock
DISCLOSURE_PROVIDER=mock
PORTFOLIO_PROVIDER=mock

# CORS settings for browser-based frontends.
# Local development example:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production example:
# CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
